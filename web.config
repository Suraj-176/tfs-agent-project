<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <handlers>
      <remove name="httpPlatformHandler" />
      <add name="httpPlatformHandler" path="*" verb="*" modules="httpPlatformHandler" resourceType="Unspecified" />
    </handlers>
    <httpPlatform processPath="C:\inetpub\tfs-agent-project\tfs-agent-project\.venv\Scripts\python.exe"
                  arguments="-m uvicorn backend.main:app --host 127.0.0.1 --port %HTTP_PLATFORM_PORT% --log-level info"
                  startupTimeLimit="300"
                  startupRetryCount="3"
                  stdoutLogEnabled="true"
                  stdoutLogFile=".\logs\iis_stdout">
      <environmentVariables>
        <environmentVariable name="PYTHONPATH" value="C:\inetpub\tfs-agent-project\tfs-agent-project" />
      </environmentVariables>
    </httpPlatform>
  </system.webServer>
</configuration>
